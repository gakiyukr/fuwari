---
import path from "node:path";
import Comments from "@components/Comments.astro";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import PostOutdatedNotice from "@components/PostOutdatedNotice.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { getPostHistory } from "@utils/git-log";
import { getPostFreshness } from "@utils/post-signals";
import { getDir } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig, profileConfig, siteConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../components/PostMeta.astro";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await entry.render();
const gitHistory = await getPostHistory(entry.filePath ?? "");
const latestRevision = gitHistory[0];
const previousRevisions = gitHistory.slice(1);
const gitUpdatedAt = latestRevision?.date ? new Date(latestRevision.date) : undefined;
const effectiveUpdated =
	gitUpdatedAt && !Number.isNaN(gitUpdatedAt.getTime())
		? gitUpdatedAt
		: entry.data.updated;
const freshness = getPostFreshness(entry.data.published, effectiveUpdated);

const datetimeFormatter = new Intl.DateTimeFormat("zh-CN", {
	dateStyle: "medium",
	timeStyle: "short",
});

const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
	dateStyle: "medium",
});

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	dateModified: formatDateToYYYYMMDD(effectiveUpdated ?? entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout
	banner={entry.data.image}
	title={entry.data.title}
	description={entry.data.description}
	lang={entry.data.lang}
	setOGTypeArticle={true}
	headings={headings}
>
	<script
		is:inline
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify(jsonLd)}
	></script>

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
		<article
			id="post-container"
			class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full"
		>
			<div class="post-reading onload-animation">
				<div class="post-reading__item">
					<div class="post-reading__icon">
						<Icon name="material-symbols:notes-rounded" />
					</div>
					<div class="text-sm">
						{remarkPluginFrontmatter.words} {i18n(I18nKey.wordsCount)}
					</div>
				</div>

				<div class="post-reading__item">
					<div class="post-reading__icon">
						<Icon name="material-symbols:schedule-outline-rounded" />
					</div>
					<div class="text-sm">
						{remarkPluginFrontmatter.minutes}{" "}
						{i18n(
							remarkPluginFrontmatter.minutes === 1
								? I18nKey.minuteCount
								: I18nKey.minutesCount,
						)}
					</div>
				</div>
			</div>

			<h1 class="font-bold mb-3 text-3xl md:text-[2.25rem]/[2.75rem]">
				{entry.data.title}
			</h1>

				<PostMetadata
					class="mb-6"
					published={entry.data.published}
					updated={effectiveUpdated}
					tags={entry.data.tags}
					category={entry.data.category}
				/>

				{freshness && (
					<PostOutdatedNotice
						status={freshness}
						published={entry.data.published}
						updated={effectiveUpdated}
						historyHref={gitHistory.length > 0 ? "#post-history" : undefined}
					/>
				)}

			{entry.data.image && (
				<ImageWrapper
					src={entry.data.image}
					basePath={path.join("content/posts/", getDir(entry.id))}
					class="mb-8 rounded-xl"
				/>
			)}

			<Markdown class="mb-6 markdown-content">
				<Content />
			</Markdown>

				{gitHistory.length > 0 && (
					<section id="post-history" class="post-history">
						<div class="post-history__hero">
							<div>
								<div class="post-history__eyebrow">Revision Trail</div>
								<h2 class="post-history__title">本文更新记录</h2>
							</div>

							<div class="post-history__stats">
								<div class="post-history__stat">
									<span class="post-history__stat-label">主要更新</span>
									<strong>{gitHistory.length}</strong>
								</div>
								{latestRevision && (
									<div class="post-history__stat">
										<span class="post-history__stat-label">最近一次</span>
										<strong>{dateFormatter.format(new Date(latestRevision.date))}</strong>
									</div>
								)}
							</div>
						</div>

						<details class="post-history__content">
							<summary class="post-history__content-summary">
								<span class="post-history__content-copy">最近更新</span>
								<span class="post-history__content-meta">
									<span>{gitHistory.length} 次更新</span>
									<Icon
										class="post-history__content-chevron"
										name="material-symbols:keyboard-arrow-down-rounded"
									/>
								</span>
							</summary>

							<div class="post-history__content-body">
								{latestRevision && (
									<div class="post-history__latest">
										<div class="post-history__item post-history__item--latest">
											<div class="post-history__line" aria-hidden="true"></div>
											<div class="post-history__dot" aria-hidden="true"></div>
											<div class="post-history__card">
												<div class="post-history__meta">
													<time datetime={latestRevision.date}>
														{datetimeFormatter.format(new Date(latestRevision.date))}
													</time>
													<span
														class:list={[
															"post-history__type",
															`post-history__type--${latestRevision.type}`,
														]}
													>
														{latestRevision.typeLabel}
													</span>
													<code class="post-history__hash">{latestRevision.hash}</code>
												</div>
												<div class="post-history__message">{latestRevision.message}</div>
											</div>
										</div>
									</div>
								)}

								{previousRevisions.length > 0 && (
									<details class="post-history__details">
										<summary>
											<span class="post-history__summary-copy">
												<Icon name="material-symbols:history-rounded" />
												<span>查看全部修订</span>
											</span>
											<span class="post-history__summary-count">
												{previousRevisions.length} 条更早记录
											</span>
										</summary>

										<ol class="post-history__timeline">
											{previousRevisions.map((item) => (
												<li class="post-history__item">
													<div class="post-history__line" aria-hidden="true"></div>
													<div class="post-history__dot" aria-hidden="true"></div>
													<div class="post-history__card">
														<div class="post-history__meta">
															<time datetime={item.date}>
																{datetimeFormatter.format(new Date(item.date))}
															</time>
															<span
																class:list={["post-history__type", `post-history__type--${item.type}`]}
															>
																{item.typeLabel}
															</span>
															<code class="post-history__hash">{item.hash}</code>
														</div>
														<div class="post-history__message">{item.message}</div>
													</div>
												</li>
											))}
										</ol>
									</details>
								)}
							</div>
						</details>
					</section>
				)}

				{licenseConfig.enable && (
					<License
						title={entry.data.title}
						slug={entry.slug}
						pubDate={entry.data.published}
					/>
				)}

				<Comments />
			</article>
	</div>
</MainGridLayout>

<style>
	.post-reading {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.1rem;
		margin-bottom: 0.9rem;
		color: color-mix(in oklab, var(--deep-text) 38%, transparent);
	}

	.post-reading__item {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.post-reading__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.6rem;
		height: 1.6rem;
		border-radius: 0.65rem;
		background: color-mix(in oklab, var(--btn-regular-bg) 88%, transparent);
	}

	.post-history {
		margin: 2.5rem 0 2rem;
		padding: 1.25rem;
		border-radius: 1.25rem;
		border: 1px solid color-mix(in oklab, var(--line-divider) 90%, transparent);
		background:
			radial-gradient(
					circle at top right,
				color-mix(in oklab, var(--primary) 9%, transparent),
				transparent 30%
			),
			var(--card-bg);
	}

	.post-history__hero {
		display: flex;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 1rem;
	}

	.post-history__eyebrow {
		margin-bottom: 0.3rem;
		color: var(--primary);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.post-history__title {
		margin: 0;
		color: var(--deep-text);
		font-size: 1.15rem;
		font-weight: 700;
	}

	.post-history__stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-self: start;
	}

	.post-history__stat {
		min-width: 7.5rem;
		padding: 0.8rem 0.95rem;
		border-radius: 1rem;
		border: 1px solid color-mix(in oklab, var(--line-divider) 88%, transparent);
		background: color-mix(in oklab, var(--btn-regular-bg) 60%, transparent);
	}

	.post-history__stat-label {
		display: block;
		margin-bottom: 0.25rem;
		color: color-mix(in oklab, var(--deep-text) 48%, transparent);
		font-size: 0.75rem;
	}

	.post-history__stat strong {
		color: var(--deep-text);
		font-size: 0.92rem;
	}

	.post-history__latest {
		margin-top: 1.15rem;
	}

	.post-history__content {
		margin-top: 1.15rem;
		border-radius: 1.05rem;
		border: 1px solid color-mix(in oklab, var(--line-divider) 82%, transparent);
		background: color-mix(in oklab, var(--card-bg) 92%, var(--btn-regular-bg) 8%);
		overflow: clip;
	}

	.post-history__content-summary {
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 1rem;
		cursor: pointer;
		user-select: none;
		color: var(--deep-text);
	}

	.post-history__content-summary::-webkit-details-marker {
		display: none;
	}

	.post-history__content-copy,
	.post-history__content-meta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.post-history__content-copy {
		font-size: 0.94rem;
		font-weight: 700;
	}

	.post-history__content-meta {
		color: color-mix(in oklab, var(--deep-text) 54%, transparent);
		font-size: 0.82rem;
		font-weight: 600;
	}

	.post-history__content-chevron {
		font-size: 1.2rem;
		transition: transform 0.18s ease;
	}

	.post-history__content[open] .post-history__content-chevron {
		transform: rotate(180deg);
	}

	.post-history__content-body {
		padding: 0 1rem 1rem;
	}

	.post-history__details summary {
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.8rem 0.95rem;
		border-radius: 1rem;
		background: color-mix(in oklab, var(--btn-regular-bg) 58%, transparent);
		color: var(--deep-text);
		cursor: pointer;
		user-select: none;
	}

	.post-history__details summary::-webkit-details-marker {
		display: none;
	}

	.post-history__summary-copy {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.92rem;
		font-weight: 600;
	}

	.post-history__summary-count {
		color: color-mix(in oklab, var(--deep-text) 54%, transparent);
		font-size: 0.82rem;
	}

	.post-history__timeline {
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
	}

	.post-history__item {
		position: relative;
		padding-left: 1.65rem;
	}

	.post-history__item--latest {
		padding-left: 1.65rem;
	}

	.post-history__item:not(:last-child) {
		padding-bottom: 0.9rem;
	}

	.post-history__line {
		position: absolute;
		left: 0.36rem;
		top: 0.5rem;
		bottom: -0.4rem;
		width: 1px;
		background: color-mix(in oklab, var(--line-divider) 90%, transparent);
	}

	.post-history__item:last-child .post-history__line {
		display: none;
	}

	.post-history__dot {
		position: absolute;
		left: 0;
		top: 0.45rem;
		width: 0.72rem;
		height: 0.72rem;
		border-radius: 999px;
		border: 2px solid color-mix(in oklab, var(--primary) 28%, white 72%);
		background: var(--card-bg);
	}

	.post-history__card {
		padding: 0.85rem 0.95rem;
		border-radius: 1rem;
		border: 1px solid color-mix(in oklab, var(--line-divider) 76%, transparent);
		background: color-mix(in oklab, var(--card-bg) 88%, var(--btn-regular-bg) 12%);
		box-shadow: inset 0 1px 0 color-mix(in oklab, white 40%, transparent);
	}

	.post-history__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.75rem;
		color: color-mix(in oklab, var(--deep-text) 48%, transparent);
		font-size: 0.8rem;
	}

	.post-history__type {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.5rem;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 700;
	}

	.post-history__type--feat {
		background: color-mix(in oklab, var(--admonitions-color-tip) 14%, transparent);
		color: color-mix(in oklab, var(--admonitions-color-tip) 78%, var(--deep-text) 22%);
	}

	.post-history__type--fix {
		background: color-mix(in oklab, var(--admonitions-color-warning) 16%, transparent);
		color: color-mix(in oklab, var(--admonitions-color-warning) 80%, var(--deep-text) 20%);
	}

	.post-history__type--content,
	.post-history__type--other {
		background: color-mix(in oklab, var(--primary) 10%, transparent);
		color: color-mix(in oklab, var(--primary) 76%, var(--deep-text) 24%);
	}

	.post-history__message {
		margin-top: 0.45rem;
		color: var(--deep-text);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.post-history__hash {
		padding: 0.2rem 0.5rem;
		border-radius: 999px;
		background: color-mix(in oklab, var(--btn-regular-bg) 86%, transparent);
		color: color-mix(in oklab, var(--deep-text) 54%, transparent);
		font-size: 0.76rem;
	}

	@media (max-width: 768px) {
		.post-history {
			padding: 1rem;
		}

		.post-history__content-summary {
			padding: 0.9rem 1rem;
		}

		.post-history__hero {
			flex-direction: column;
			gap: 1rem;
		}

		.post-history__stats {
			width: 100%;
		}

		.post-history__stat {
			flex: 1 1 10rem;
		}

		.post-history__details summary {
			padding: 0.8rem 0.9rem;
		}

		.post-history__content-meta {
			font-size: 0.78rem;
		}
	}
</style>
