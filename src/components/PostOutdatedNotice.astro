---
const { date } = Astro.props;

const lastModified = new Date(date);
const now = new Date();

const days = Math.floor(
  (now.getTime() - lastModified.getTime()) / (1000 * 60 * 60 * 24)
);

const outdated = days > 1; // 超过1天显示
---

{outdated && (
  <div class="outdated-notice">
    ⚠️ 此文章最后更新于 {days} 天前，部分内容可能已过时。
  </div>
)}

<style>
.outdated-notice {
  margin: 30px 0;
  padding: 14px 18px;

  border-radius: 10px;
  background: rgba(255, 170, 0, 0.12);
  border-left: 4px solid #ff9800;

  color: #b26a00;
  font-size: 15px;

  line-height: 1.6;
}
</style>