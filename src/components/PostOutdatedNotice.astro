---
import { Icon } from "astro-icon/components";
import type { PostFreshness } from "@/utils/post-signals";

interface Props {
	status: PostFreshness;
}

const { status } = Astro.props;
---

<aside class:list={["post-freshness", `post-freshness--${status.level}`]}>
	<div class="post-freshness__badge">
		<Icon name={status.icon} class="text-[1rem]" />
		<span>{status.label}</span>
	</div>

	<div class="post-freshness__content">
		<p class="post-freshness__text">{status.description}</p>
	</div>
</aside>

<style>
	.post-freshness {
		margin-bottom: 1.5rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.625rem 0.875rem;
		border: 1px solid var(--freshness-border);
		border-left-width: 4px;
		border-radius: 0.875rem;
		background: var(--freshness-bg);
		color: var(--freshness-text);
		font-size: 0.8125rem;
		line-height: 1.45;
	}

	.post-freshness__badge {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		flex-shrink: 0;
		padding: 0.3rem 0.55rem;
		border-radius: 999px;
		background: var(--freshness-badge-bg);
		color: var(--freshness-accent);
		font-weight: 700;
	}

	.post-freshness__content {
		min-width: 0;
	}

	.post-freshness__text {
		margin: 0;
		color: var(--freshness-text);
	}

	.post-freshness--aging {
		--freshness-bg: color-mix(in oklab, var(--admonitions-color-tip) 10%, transparent);
		--freshness-border: color-mix(in oklab, var(--admonitions-color-tip) 38%, transparent);
		--freshness-badge-bg: color-mix(in oklab, var(--admonitions-color-tip) 16%, transparent);
		--freshness-accent: color-mix(in oklab, var(--admonitions-color-tip) 82%, black 12%);
		--freshness-text: color-mix(in oklab, var(--admonitions-color-tip) 62%, var(--text) 38%);
	}

	.post-freshness--stale {
		--freshness-bg: color-mix(in oklab, var(--admonitions-color-warning) 11%, transparent);
		--freshness-border: color-mix(in oklab, var(--admonitions-color-warning) 42%, transparent);
		--freshness-badge-bg: color-mix(in oklab, var(--admonitions-color-warning) 17%, transparent);
		--freshness-accent: color-mix(in oklab, var(--admonitions-color-warning) 88%, black 12%);
		--freshness-text: color-mix(in oklab, var(--admonitions-color-warning) 58%, var(--text) 42%);
	}

	.post-freshness--legacy {
		--freshness-bg: color-mix(in oklab, var(--admonitions-color-caution) 10%, transparent);
		--freshness-border: color-mix(in oklab, var(--admonitions-color-caution) 44%, transparent);
		--freshness-badge-bg: color-mix(in oklab, var(--admonitions-color-caution) 16%, transparent);
		--freshness-accent: color-mix(in oklab, var(--admonitions-color-caution) 84%, black 10%);
		--freshness-text: color-mix(in oklab, var(--admonitions-color-caution) 55%, var(--text) 45%);
	}

	@media (max-width: 768px) {
		.post-freshness {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
